<!-- File Path: src/HRManagement.Web/Views/Departments/Index.cshtml -->
<!-- Purpose: Department list view with member counts. -->
<!-- Code Explanation: Renders departments list using a premium table with DataTables support. -->

@model IEnumerable<HRManagement.Domain.Entities.Department>
@{
    ViewData["Title"] = "Departments";
    ViewData["BreadcrumbActive"] = "Departments";
}

<div class="card border-0 shadow-sm p-4" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color) !important; border-radius: 12px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0 text-gradient">Department Directory</h4>
            <p class="text-secondary small m-0">View company organization and member allocation.</p>
        </div>
        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary btn-sm px-4"><i class="fa-solid fa-plus me-2"></i>Add Department</a>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3 text-secondary" style="font-size: 3.5rem;">
                <i class="fa-solid fa-sitemap text-muted"></i>
            </div>
            <h5 class="fw-bold">No departments found</h5>
            <p class="text-secondary small">There are no department entities configured in the platform.</p>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-primary btn-sm px-4 mt-2"><i class="fa-solid fa-plus me-2"></i>Add Department</a>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table id="departmentsTable" class="table table-hover align-middle" style="width:100%;">
                <thead>
                    <tr>
                        <th>Department Name</th>
                        <th>Headcount</th>
                        <th>Created Date</th>
                        @if (User.IsInRole("Admin"))
                        {
                            <th>Actions</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var dept in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@dept.Name</td>
                            <td>
                                <span class="badge bg-primary-subtle text-primary px-3 py-2">
                                    @(dept.Employees?.Count ?? 0) Employees
                                </span>
                            </td>
                            <td>@dept.CreatedDate.ToString("yyyy-MM-dd")</td>
                            @if (User.IsInRole("Admin"))
                            {
                                <td>
                                    <a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-outline-primary" title="Edit Department"><i class="fa-solid fa-pen"></i></a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#departmentsTable').DataTable({
                responsive: true,
                pageLength: 10,
                language: {
                    searchPlaceholder: "Search departments..."
                }
            });
        });
    </script>
}
