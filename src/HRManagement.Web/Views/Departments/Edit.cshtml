<!-- File Path: src/HRManagement.Web/Views/Departments/Edit.cshtml -->
<!-- Purpose: Edit department name view. -->
<!-- Code Explanation: Renders form to update department details. -->

@model HRManagement.Domain.Entities.Department
@{
    ViewData["Title"] = "Edit Department";
    ViewData["BreadcrumbActive"] = "Edit Department";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color) !important; border-radius: 12px;">
            <div class="mb-4">
                <h4 class="fw-bold m-0">Edit Department</h4>
                <p class="text-secondary small m-0">Update division naming parameters.</p>
            </div>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="RowVersion" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-semibold">Department Name</label>
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
