<!-- File Path: src/HRManagement.Web/Views/Leaves/History.cshtml -->
<!-- Purpose: Display user's own leave request history. -->
<!-- Code Explanation: Renders a DataTable of leave requests with options to cancel pending/approved future leaves. -->

@model IEnumerable<HRManagement.Domain.Entities.LeaveRequest>
@{
    ViewData["Title"] = "Leave History";
    ViewData["BreadcrumbActive"] = "Leave History";
}

<div class="card border-0 shadow-sm p-4" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color) !important; border-radius: 12px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0">My Leave Requests</h4>
            <p class="text-secondary small m-0">Track the status and details of your leave history.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-primary btn-sm px-4"><i class="fa-solid fa-plus me-2"></i>New Request</a>
    </div>

    @Html.AntiForgeryToken()

    <div class="table-responsive">
        <table id="historyTable" class="table table-hover align-middle" style="width:100%;">
            <thead>
                <tr>
                    <th>Type</th>
                    <th>Start Date</th>
                    <th>End Date</th>
                    <th>Days</th>
                    <th>Reason</th>
                    <th>Status</th>
                    <th>Comments</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var lr in Model)
                {
                    <tr>
                        <td class="fw-semibold">@lr.LeaveType?.Name</td>
                        <td>@lr.StartDate.ToString("yyyy-MM-dd")</td>
                        <td>@lr.EndDate.ToString("yyyy-MM-dd")</td>
                        <td><span class="badge bg-secondary px-2">@lr.TotalDays days</span></td>
                        <td><span class="text-truncate d-inline-block" style="max-width: 150px;" title="@lr.Reason">@lr.Reason</span></td>
                        <td>
                            @switch (lr.Status)
                            {
                                case "Pending":
                                    <span class="badge bg-warning-subtle text-warning px-3 py-2">Pending</span>
                                    break;
                                case "Approved":
                                    <span class="badge bg-success-subtle text-success px-3 py-2">Approved</span>
                                    break;
                                case "Rejected":
                                    <span class="badge bg-danger-subtle text-danger px-3 py-2">Rejected</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary-subtle text-secondary px-3 py-2">@lr.Status</span>
                                    break;
                            }
                        </td>
                        <td class="text-secondary small">@lr.Comments</td>
                        <td>
                            @if (lr.Status == "Pending" || (lr.Status == "Approved" && lr.StartDate > DateTime.Today))
                            {
                                <button class="btn btn-sm btn-outline-danger cancel-btn" data-id="@lr.Id">
                                    <i class="fa-solid fa-ban me-1"></i>Cancel
                                </button>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#historyTable').DataTable({
                responsive: true,
                order: [[1, "desc"]],
                pageLength: 10,
                language: {
                    searchPlaceholder: "Search requests..."
                }
            });

            $('.cancel-btn').on('click', function () {
                var id = $(this).data('id');
                var token = $('input[name="__RequestVerificationToken"]').val();

                Swal.fire({
                    title: 'Are you sure?',
                    text: "Do you want to cancel this leave request?",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Yes, cancel it!',
                    background: 'var(--bg-secondary)',
                    color: 'var(--text-primary)'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: '@Url.Action("Cancel", "Leaves")',
                            type: 'POST',
                            data: {
                                id: id,
                                __RequestVerificationToken: token
                            },
                            success: function (response) {
                                if (response.success) {
                                    toastr.success(response.message);
                                    setTimeout(function() {
                                        window.location.reload();
                                    }, 1000);
                                } else {
                                    toastr.error(response.message);
                                }
                            },
                            error: function () {
                                toastr.error("An error occurred during request cancellation.");
                            }
                        });
                    }
                });
            });
        });
    </script>
}
