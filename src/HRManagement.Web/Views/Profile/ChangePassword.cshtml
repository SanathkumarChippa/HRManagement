<!-- File Path: src/HRManagement.Web/Views/Profile/ChangePassword.cshtml -->
<!-- Purpose: Form to modify current password. -->
<!-- Code Explanation: Renders security fields that connect with UserManager services. -->

@model HRManagement.Web.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    ViewData["BreadcrumbActive"] = "Change Password";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-0 shadow-sm p-4" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color) !important; border-radius: 12px;">
            <div class="mb-4">
                <h4 class="fw-bold m-0 text-gradient">Update Password</h4>
                <p class="text-secondary small m-0">Ensure account security by configuring a strong password.</p>
            </div>

            <form asp-action="ChangePassword" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="CurrentPassword" class="form-label fw-semibold"></label>
                    <input asp-for="CurrentPassword" class="form-control" placeholder="Current credentials..." required />
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                    <input asp-for="NewPassword" class="form-control" placeholder="Minimum 6 characters..." required />
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Repeat new password..." required />
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Change Password</button>
                </div>
            </form>
        </div>
    </div>
</div>
