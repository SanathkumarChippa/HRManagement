@{
    Layout = null;
    var theme = Context.Request.Cookies["ThemePreference"] ?? "light";
}
<!DOCTYPE html>
<html lang="en" data-bs-theme="@theme">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Change Your Password - HR Management Platform</title>

    <!-- FontAwesome & Outfit font -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
        body {
            font-family: 'Outfit', sans-serif;
            background-color: var(--bg-primary);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }
        .force-card {
            background-color: var(--bg-secondary);
            border: 1px solid var(--border-color) !important;
            border-radius: 16px;
            max-width: 480px;
            width: 100%;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
        }
        .text-gradient {
            background: linear-gradient(135deg, var(--primary-color), #3b82f6);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
    </style>
</head>
<body>
    <div class="force-card p-4 mx-3">
        <div class="text-center mb-4">
            <div class="text-primary mb-2" style="font-size: 3rem;">
                <i class="fa-solid fa-key-skeleton fa-key"></i>
            </div>
            <h4 class="fw-bold m-0 text-gradient">Change Your Password</h4>
            <p class="text-secondary small mt-1">For security reasons you must change your temporary password before continuing.</p>
        </div>

        <div id="modalChangePasswordErrors" class="alert alert-danger d-none small"></div>

        <form id="modalChangePasswordForm" method="post" action="/Profile/ChangePasswordJson">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label for="modalCurrentPassword" class="form-label fw-semibold" style="font-size: 0.85rem;">Current Password</label>
                <input type="password" name="CurrentPassword" id="modalCurrentPassword" class="form-control text-body bg-transparent" required />
            </div>
            <div class="mb-3">
                <label for="modalNewPassword" class="form-label fw-semibold" style="font-size: 0.85rem;">New Password</label>
                <input type="password" name="NewPassword" id="modalNewPassword" class="form-control text-body bg-transparent" required />
                <small class="text-secondary d-block mt-1" style="font-size: 0.75rem; line-height: 1.2;">
                    Min 8 characters, at least 1 uppercase, 1 lowercase, 1 number, and 1 special character.
                </small>
            </div>
            <div class="mb-3">
                <label for="modalConfirmPassword" class="form-label fw-semibold" style="font-size: 0.85rem;">Confirm Password</label>
                <input type="password" name="ConfirmPassword" id="modalConfirmPassword" class="form-control text-body bg-transparent" required />
            </div>
            <div class="d-grid gap-2 mt-4">
                <button type="submit" class="btn btn-primary py-2 fw-semibold"><i class="fa-solid fa-lock me-2"></i>Change Password</button>
            </div>
        </form>

        <div class="text-center mt-3 pt-3 border-top">
            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-link text-danger text-decoration-none"><i class="fa-solid fa-right-from-bracket me-1"></i>Cancel & Sign Out</button>
            </form>
        </div>
    </div>

    <!-- Core Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>

    <script>
        $(document).ready(function () {
            const form = document.getElementById('modalChangePasswordForm');
            const errorDiv = document.getElementById('modalChangePasswordErrors');

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                errorDiv.classList.add('d-none');
                errorDiv.innerText = '';

                const currentPwd = document.getElementById('modalCurrentPassword').value;
                const newPwd = document.getElementById('modalNewPassword').value;
                const confPwd = document.getElementById('modalConfirmPassword').value;

                if (newPwd !== confPwd) {
                    errorDiv.innerText = 'The new password and confirmation password do not match.';
                    errorDiv.classList.remove('d-none');
                    return;
                }

                if (newPwd.length < 8) {
                    errorDiv.innerText = 'New password must be at least 8 characters long.';
                    errorDiv.classList.remove('d-none');
                    return;
                }

                const regex = /^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[@@$!%*?&])[A-Za-z\d@@$!%*?&]{8,}$/;
                if (!regex.test(newPwd)) {
                    errorDiv.innerText = 'Password must contain at least one uppercase letter, one lowercase letter, one digit, and one special character.';
                    errorDiv.classList.remove('d-none');
                    return;
                }

                const formData = new FormData(form);
                fetch('/Profile/ChangePasswordJson', {
                    method: 'POST',
                    body: formData
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        toastr.success('Password changed successfully! Redirecting...');
                        setTimeout(function() {
                            window.location.href = '/';
                        }, 1500);
                    } else {
                        errorDiv.innerText = data.message || 'An error occurred.';
                        errorDiv.classList.remove('d-none');
                    }
                })
                .catch(err => {
                    errorDiv.innerText = 'Network error occurred.';
                    errorDiv.classList.remove('d-none');
                });
            });
        });
    </script>
</body>
</html>
