<!-- File Path: src/HRManagement.Web/Views/Employees/Edit.cshtml -->
<!-- Purpose: Form page to edit employee profile parameters. -->
<!-- Code Explanation: Renders pre-populated input fields and binding parameters to enable updating employee details. -->

@model HRManagement.Domain.Entities.Employee
@{
    ViewData["Title"] = "Edit Employee";
    ViewData["BreadcrumbActive"] = "Edit Employee";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color) !important; border-radius: 12px;">
            <h4 class="fw-bold mb-4"><i class="fa-solid fa-user-pen text-primary me-2"></i>Edit Employee</h4>

            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="EmployeeCode" />
                <input type="hidden" asp-for="DateOfJoining" />

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Employee Code</label>
                        <input asp-for="EmployeeCode" class="form-control" readonly />
                        <span class="text-secondary small d-block" style="font-size: 0.75rem; color: var(--text-secondary);"><i class="fa-solid fa-circle-info me-1"></i>Employee code is system generated.</span>
                        <span class="text-secondary small d-block" style="font-size: 0.75rem;"><i class="fa-solid fa-circle-info me-1"></i>This field cannot be modified.</span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small fw-semibold">Date of Joining</label>
                        <input asp-for="DateOfJoining" type="date" class="form-control" readonly />
                        <span class="text-secondary small d-block" style="font-size: 0.75rem;"><i class="fa-solid fa-circle-info me-1"></i>This field cannot be modified.</span>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label small fw-semibold">First Name</label>
                        <input asp-for="FirstName" class="form-control" required />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label small fw-semibold">Last Name</label>
                        <input asp-for="LastName" class="form-control" required />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label small fw-semibold">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" readonly />
                        <span class="text-secondary small d-block" style="font-size: 0.75rem; color: var(--text-secondary);"><i class="fa-solid fa-circle-info me-1"></i>Corporate email cannot be changed.</span>
                        <span class="text-secondary small d-block" style="font-size: 0.75rem;"><i class="fa-solid fa-circle-info me-1"></i>This field cannot be modified.</span>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label small fw-semibold">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" required />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label small fw-semibold">Gender</label>
                        <select asp-for="Gender" class="form-select" required>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Designation" class="form-label small fw-semibold">Designation</label>
                        <input asp-for="Designation" class="form-control" required />
                        <span asp-validation-for="Designation" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DepartmentId" class="form-label small fw-semibold">Department</label>
                        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId" required></select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ManagerId" class="form-label small fw-semibold">Reporting Manager</label>
                        <select asp-for="ManagerId" class="form-select" asp-items="ViewBag.ManagerId" disabled>
                            <option value="">Select Manager (None)</option>
                        </select>
                        <input type="hidden" asp-for="ManagerId" />
                        <span class="text-secondary small d-block" style="font-size: 0.75rem; color: var(--text-secondary);"><i class="fa-solid fa-circle-info me-1"></i>Assigned by HR department.</span>
                        <span class="text-secondary small d-block" style="font-size: 0.75rem;"><i class="fa-solid fa-circle-info me-1"></i>This field cannot be modified.</span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EmploymentStatus" class="form-label small fw-semibold">Employment Status</label>
                        <select asp-for="EmploymentStatus" class="form-select" required>
                            <option value="Active">Active</option>
                            <option value="Resigned">Resigned</option>
                            <option value="Terminated">Terminated</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>
