<!-- File Path: src/HRManagement.Web/Views/Employees/Create.cshtml -->
<!-- Purpose: Form page to onboard a new employee. -->
<!-- Code Explanation: Renders Bootstrap input fields, dropdown select list variables (for departments and manager selection), and configures validations. -->

@model HRManagement.Domain.Entities.Employee
@{
    ViewData["Title"] = "Onboard Employee";
    ViewData["BreadcrumbActive"] = "Onboard Employee";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color) !important; border-radius: 12px;">
            <h4 class="fw-bold mb-4"><i class="fa-solid fa-user-plus me-2 text-primary"></i>Onboard Employee</h4>
            
            <form asp-action="Create" method="post" autocomplete="off">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="FirstName" class="form-label small fw-semibold">First Name</label>
                        <input asp-for="FirstName" class="form-control" placeholder="e.g. John" required />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="LastName" class="form-label small fw-semibold">Last Name</label>
                        <input asp-for="LastName" class="form-control" placeholder="e.g. Doe" required />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label small fw-semibold">Email Address</label>
                        <input asp-for="Email" type="email" class="form-control" placeholder="e.g. email@company.com" required />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label small fw-semibold">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="e.g. 1234567890" required />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Gender" class="form-label small fw-semibold">Gender</label>
                        <select asp-for="Gender" class="form-select" required>
                            <option value="">Select Gender</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Designation" class="form-label small fw-semibold">Designation</label>
                        <input asp-for="Designation" class="form-control" placeholder="e.g. Senior Architect" required />
                        <span asp-validation-for="Designation" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DepartmentId" class="form-label small fw-semibold">Department</label>
                        <select asp-for="DepartmentId" class="form-select" asp-items="ViewBag.DepartmentId" required>
                            <option value="">Select Department</option>
                        </select>
                        <span asp-validation-for="DepartmentId" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ManagerId" class="form-label small fw-semibold">Reporting Manager</label>
                        <select asp-for="ManagerId" class="form-select" asp-items="ViewBag.ManagerId">
                            <option value="">Select Manager (None)</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="DateOfJoining" class="form-label small fw-semibold">Date of Joining</label>
                        <input asp-for="DateOfJoining" type="date" class="form-control" required />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="EmploymentStatus" class="form-label small fw-semibold">Employment Status</label>
                        <select asp-for="EmploymentStatus" class="form-select" required>
                            <option value="Active">Active</option>
                            <option value="Resigned">Resigned</option>
                            <option value="Terminated">Terminated</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex gap-2 justify-content-end mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    <button type="submit" class="btn btn-primary px-4">Save & Seed</button>
                </div>
            </form>
        </div>
    </div>
</div>
