<!-- File Path: src/HRManagement.Web/Views/Employees/DeletedList.cshtml -->
<!-- Purpose: Archive of soft-deleted employee records for recovery. -->

@model IEnumerable<HRManagement.Domain.Entities.Employee>
@{
    ViewData["Title"] = "Deleted Employees Archive";
    ViewData["BreadcrumbActive"] = "Deleted Employees";
}

<div class="card border-0 shadow-sm p-4" style="background-color: var(--bg-secondary); border: 1px solid var(--border-color) !important; border-radius: 12px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0"><i class="fa-solid fa-trash-arrow-up text-warning me-2"></i>Deleted Employees Archive</h4>
            <p class="text-secondary small m-0">Review previously soft-deleted profiles and restore access if needed.</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm px-4"><i class="fa-solid fa-arrow-left me-2"></i>Back to Directory</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <div class="mb-3 text-secondary" style="font-size: 3.5rem;">
                <i class="fa-solid fa-trash-can text-muted"></i>
            </div>
            <h5 class="fw-bold">No deleted employees found</h5>
            <p class="text-secondary small mb-0">The soft-delete archive is currently empty.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table id="deletedEmployeesTable" class="table table-hover align-middle" style="width:100%;">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Department</th>
                        <th>Designation</th>
                        <th>Deleted Date</th>
                        <th>Deleted By</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var emp in Model)
                    {
                        <tr>
                            <td class="fw-semibold text-danger">@emp.EmployeeCode</td>
                            <td>@emp.FirstName @emp.LastName</td>
                            <td>@emp.Email</td>
                            <td>@emp.Department?.Name</td>
                            <td>@emp.Designation</td>
                            <td class="small text-secondary">@emp.DeletedDate?.ToString("yyyy-MM-dd HH:mm")</td>
                            <td class="small fw-semibold">@emp.DeletedBy</td>
                            <td>
                                <form asp-action="Restore" asp-route-id="@emp.Id" method="post" onsubmit="return confirm('Are you sure you want to restore this employee record?');" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-success px-3" title="Restore Employee">
                                        <i class="fa-solid fa-trash-arrow-up me-1"></i>Restore
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            if ($('#deletedEmployeesTable').length > 0) {
                $('#deletedEmployeesTable').DataTable({
                    responsive: true,
                    pageLength: 10,
                    language: {
                        searchPlaceholder: "Search deleted..."
                    }
                });
            }
        });
    </script>
}
